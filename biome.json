{
	"$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"files": {
		"includes": [
			"**/*.js",
			"**/*.ts",
			"**/*.mjs",
			"**/*.json",
			"**/*.css",
			"**/*.yml",
			"**/*.yaml",
			"!!**/node_modules",
			"!!themes/bryan-chasko-theme/layouts",
			"!!themes/bryan-chasko-theme/assets/js/fuse.basic.min.js",
			"!!themes/bryan-chasko-theme/assets/js/notes-tilt.min.js",
			"!!themes/bryan-chasko-theme/assets/css/components/terminal.css",
			"!!public",
			"!!test-results",
			"!!test-report"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"complexity": {
				"noImportantStyles": "off"
			},
			"suspicious": {
				"useIterableCallbackReturn": "warn"
			}
		}
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"css": {
		"formatter": {
			"enabled": true,
			"indentStyle": "tab"
		},
		"linter": {
			"enabled": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	}
}
